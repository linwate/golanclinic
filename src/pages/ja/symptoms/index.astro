---
import Layout from '../../../layouts/Layout.astro'
import { indexMeta } from '../../../data/symptoms'

const lang = 'ja'
const meta = indexMeta[lang]
---

<Layout title={meta.title} description={meta.description} lang={lang} pathname="symptoms">
  <section class="fv-hero">
    <div class="container">
      <h1>{meta.h1}</h1>
      <p class="fv-tagline">{meta.intro}</p>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <p class="symptom-index-lead">症状に最も近い分類を選んで、原因と治療の方向性を確認してください。</p>
      <div class="symptom-cat-grid">

        <a href="/ja/symptoms/shoulder/" class="symptom-cat-card">
          <span class="symptom-cat-label">肩の痛み</span>
          <span class="symptom-cat-sub">五十肩・腱板断裂・インピンジメント</span>
        </a>

        <a href="/ja/symptoms/neck/" class="symptom-cat-card">
          <span class="symptom-cat-label">頸部の痛み</span>
          <span class="symptom-cat-sub">頸椎神経根症・頸因性頭痛・しびれ</span>
        </a>

        <a href="/ja/symptoms/back/" class="symptom-cat-card">
          <span class="symptom-cat-label">腰痛・下背部痛</span>
          <span class="symptom-cat-sub">椎間板・仙腸関節・坐骨神経痛</span>
        </a>

        <a href="/ja/symptoms/hip/" class="symptom-cat-card">
          <span class="symptom-cat-label">股関節・臀部の痛み</span>
          <span class="symptom-cat-sub">股関節変性・梨状筋・大転子</span>
        </a>

        <a href="/ja/symptoms/knee/" class="symptom-cat-card">
          <span class="symptom-cat-label">膝関節の変性</span>
          <span class="symptom-cat-sub">変形性膝関節症・半月板・膝蓋腱炎</span>
        </a>

        <a href="/ja/symptoms/foot/" class="symptom-cat-card">
          <span class="symptom-cat-label">足・足首の痛み</span>
          <span class="symptom-cat-sub">足底筋膜炎・足関節不安定・アキレス腱</span>
        </a>

        <a href="/ja/symptoms/elbow-wrist/" class="symptom-cat-card">
          <span class="symptom-cat-label">肘・手首の痛み</span>
          <span class="symptom-cat-sub">テニス肘・手根管・TFCC・ばね指</span>
        </a>

        <a href="/ja/symptoms/neuropathy/" class="symptom-cat-card">
          <span class="symptom-cat-label">神経障害・神経痛</span>
          <span class="symptom-cat-sub">DPN・神経解套・しびれ</span>
        </a>

        <a href="https://twmedpro.tw" target="_blank" rel="noopener noreferrer" class="symptom-cat-card">
          <span class="symptom-cat-label">スポーツ傷害</span>
          <span class="symptom-cat-sub">野球・サッカー・ピックルボール</span>
        </a>

        <a href="/ja/treatment-faq/" class="symptom-cat-card">
          <span class="symptom-cat-label">血管治療</span>
          <span class="symptom-cat-sub">TAME・異常新生血管</span>
        </a>

      </div>
    </div>
  </section>
</Layout>
