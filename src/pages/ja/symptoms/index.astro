---
import Layout from '../../../layouts/Layout.astro'
import { indexMeta } from '../../../data/symptoms'

const lang = 'ja'
const meta = indexMeta[lang]
---

<Layout title={meta.title} description={meta.description} lang={lang} pathname="symptoms">
  <section class="fv-hero">
    <div class="container">
      <h1>{meta.h1}</h1>
      <p class="fv-tagline">{meta.intro}</p>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <p class="symptom-index-lead">症状に最も近い分類を選んで、原因と治療の方向性を確認してください。</p>
      <div class="symptom-cat-grid">

        <a href="/ja/symptoms/shoulder/" class="symptom-cat-card">
          <span class="symptom-cat-label">肩・首の痛み</span>
          <span class="symptom-cat-sub">五十肩・腱板断裂・頸椎神経根症</span>
        </a>

        <a href="/ja/symptoms/back/" class="symptom-cat-card">
          <span class="symptom-cat-label">腰痛・下背部痛</span>
          <span class="symptom-cat-sub">椎間板ヘルニア・仙腸関節・坐骨神経痛</span>
        </a>

        <a href="/ja/symptoms/knee/" class="symptom-cat-card">
          <span class="symptom-cat-label">膝関節の変性</span>
          <span class="symptom-cat-sub">変形性膝関節症・半月板・膝蓋腱炎</span>
        </a>

        <a href="/ja/symptoms/foot/" class="symptom-cat-card">
          <span class="symptom-cat-label">足・足首の痛み</span>
          <span class="symptom-cat-sub">足底筋膜炎・足関節不安定・アキレス腱炎</span>
        </a>

        <a href="/ja/symptoms/elbow-wrist/" class="symptom-cat-card">
          <span class="symptom-cat-label">肘・手首の痛み</span>
          <span class="symptom-cat-sub">テニス肘・手根管症候群・TFCC・ばね指</span>
        </a>

        <a href="/ja/symptoms/neuropathy/" class="symptom-cat-card">
          <span class="symptom-cat-label">神経障害・神経痛</span>
          <span class="symptom-cat-sub">DPN・神経解套・手足のしびれ</span>
        </a>

      </div>
    </div>
  </section>
</Layout>
