---
import Layout from '../../layouts/Layout.astro'

const lang = 'ja' as const

const lineUrl = 'https://line.me/R/ti/p/@twmedpro'
const mailUrl = 'mailto:info@colanclinic.com'

const generalCare = [
  'どの治療後も、24時間以内は入浴をお控えください',
  '注射部位の軽い痠痛や腫れは正常な反応です',
  '消炎鎮痛薬（NSAIDs・イブプロフェンなど）の使用はお控えください。痛みにはアセトアミノフェン（タイレノールなど）をご使用ください',
  '発熱・注射部位の腫れや熱感の悪化・異常な脱力感が現れた場合は、速やかにご連絡ください',
  '受付費・診察料は現金のみ。自費治療は現金およびクレジットカード（Visa・Mastercard）がご利用いただけます。',
]

const treatments = [
  {
    title: 'PRP療法',
    faqs: [
      { q: 'PRP注射後、なぜ痛みが増すことがあるのですか？', a: 'PRPは軽度の炎症を誘発することで修復メカニズムを起動させるため、注射後1〜2週間以内に局所的な痠痛や腫れが現れるのは正常な反応です。最も強く感じるのは注射後48時間以内で、一部の患者様では2週間ほど続く場合があります。アイシングやアセトアミノフェンで緩和できます。' },
      { q: 'PRP後に消炎鎮痛薬を飲んでも大丈夫ですか？', a: 'お勧めしません。NSAIDsやステロイドは炎症反応を抑制しますが、この炎症こそがPRPの修復機序に必要です。どうしても痛みがある場合はアセトアミノフェンのみ服用してください。' },
      { q: 'PRP後、いつから運動できますか？', a: '注射後48〜72時間は激しい運動をお控えください。通常の歩行は問題ありません。1〜2週間後に痠痛が落ち着いてきたら、段階的にリハビリを開始できます。高負荷運動については医師にご確認ください。' },
      { q: 'PRP後の食事で気をつけることはありますか？', a: 'タンパク質・ビタミンB・ビタミンCを積極的に摂取してください。治療前後1週間はアルコールを避けてください。アルコールは血小板の質に影響します。' },
    ],
  },
  {
    title: '増生療法（ブドウ糖注射）',
    faqs: [
      { q: '増生療法の注射後はどんな感じですか？', a: '注射部位に局所的な痠痛が現れることがあります。通常1〜3日で落ち着きますが、まれに7日ほど続く場合もあります。正常な修復反応ですので、アイシングやアセトアミノフェンで対応してください。消炎鎮痛薬はお避けください。' },
      { q: '術後ケアはPRPと同じですか？', a: '基本的には同じです。消炎鎮痛薬を避け、激しい運動を控え、栄養を十分に摂ることが大切です。増生療法の痠痛はPRPより軽めで、回復期間も短い傾向があります。' },
    ],
  },
  {
    title: '針刀整合治療',
    faqs: [
      { q: '針刀治療後の注意事項を教えてください。', a: '治療当日は入浴・水泳を避け、針孔を24時間乾燥した状態に保ってください。治療部位に痠痛や軽い内出血が現れることがありますが、1〜3日で治まる正常な反応です。48時間は激しい運動をお控えください（通常の歩行は問題ありません）。発熱や腫れ・熱感の悪化がある場合はすぐにご連絡ください。' },
      { q: '針刀治療後もリハビリを続けられますか？', a: 'はい、むしろ推奨します。針刀で筋膜の癒着が解放された後は、適切なストレッチやリハビリ運動との組み合わせが効果を高めます。治療後2〜3日で痠痛が落ち着いてから、痛みを引き起こさない範囲で始めてください。' },
    ],
  },
  {
    title: 'BMAC（骨髄細胞濃縮液）',
    faqs: [
      { q: '骨髄採取は痛いですか？', a: '採取前に局所麻醉を行いますので、痛みは最小限に抑えられます。採取中に軽い圧迫感や痠痛を感じる方もいます。採取部位は骨盤の腸骨（腰の下あたりの硬い骨）で、脊椎ではありませんので神経への影響はありません。骨髄は血液と同様に自然に再生されます。' },
      { q: 'BMACと脊髄液は関係がありますか？', a: 'まったく関係ありません。骨髄は骨の中にある造血組織で、骨盤の腸骨から採取します。脊髄液は脊髄神経を包む液体とは全く異なるものです。BMAC治療で脊椎や神経系に触れることはありません。' },
      { q: '入院は必要ですか？', a: '不要です。治療全体で約1〜1.5時間、外来で完結します。少し休憩の後、当日中にご帰宅いただけます。当日の運転はお控えいただき、どなたかにお迎えをお願いすることをお勧めします。' },
      { q: 'BMAC後、いつから運動できますか？', a: '治療後48〜72時間は激しい活動や過度な負荷をお避けください。通常は1〜2週間後から軽いリハビリを開始できます。具体的なスケジュールは診察時にご確認ください。' },
    ],
  },
  {
    title: 'Simple TAME（超音波導引微細動脈栓塞）',
    faqs: [
      { q: 'ゴラン診療所のTAMEはカテーテル手術ですか？', a: 'いいえ。当院が行うのはSimple TAMEで、超音波をリアルタイムで使いながら、異常新生血管に直接薬剤を注射します。カテーテルの挿入は不要で、入院も必要なく、外来で当日中に完結します。' },
      { q: 'Simple TAME注射後の注意事項は？', a: '注射後24時間は入浴をお控えください。注射部位に軽い痠痛が現れることがありますが、1〜3日で治まります。翌日から痛みを伴わない程度の軽い活動は可能です。激しい運動や重い負荷は段階的に再開してください。' },
      { q: 'Simple TAMEとカテーテル式TAMEの違いは？', a: 'カテーテル式TAMEは手首や鼠径部から血管内にカテーテルを挿入します。Simple TAMEは超音波導引下で体表から直接注射するため、侵襲性が低く回復も早く、外来で完結します。どちらも疼痛の原因となる異常新生血管の除去を目的としており、適応する患者様や重症度は異なります。' },
      { q: '入院は必要ですか？', a: '不要です。Simple TAMEは外来治療で、注射後少し休憩していただいた後、そのままお帰りいただけます。' },
      { q: '何回治療が必要ですか？', a: '通常2〜3回が目安です。治療間隔は個人の回復状況によります。医師が超音波所見をもとに回数と間隔をご説明します。' },
    ],
  },
  {
    title: '関節ヒアルロン酸注射',
    faqs: [
      { q: 'ヒアルロン酸注射後の注意事項は？', a: '注射後24〜48時間は激しい運動や長時間の負重をお避けください。注射部位に軽い腫れや痠痛が出ることがありますが、アイシングで対応できます。24時間は注射部位を温めないようにしてください。' },
      { q: '効果はいつ出ますか？どのくらいの頻度で打ちますか？', a: '個人差がありますが、通常注射後1〜4週間で徐々に改善を感じる方が多いです。製剤によって効果は6ヶ月〜1年持続します。再注射のタイミングは医師とご相談ください。' },
    ],
  },
  {
    title: 'SportVis（軟部組織用ヒアルロン酸）',
    faqs: [
      { q: 'SportVisと通常のヒアルロン酸の違いは？', a: '通常のヒアルロン酸は主に関節の潤滑が目的です。SportVisは肌腱・靭帯修復専用に設計された特殊ヒアルロン酸で、損傷した軟部組織に浸透し、修復・潤滑・炎症制御の3つの作用を持ちます。台湾TFDAで肌腱・靭帯修復への使用が認可されている唯一の製剤です。' },
      { q: 'SportVis注射後の注意事項は？', a: '注射部位によっては、注射後に数回特定の動作（肘の屈伸・回旋など）を行うよう指示されることがあります。注射後24〜48時間は激しい運動をお控えください。通常の日常活動は問題ありません。術後の不快感はPRPより軽めです。' },
      { q: 'SportVisは何回打ちますか？', a: '標準的な療程は2回で、間隔は4〜7日です。急性の捻挫には受傷後48時間以内に初回投与するのが最も効果的です。' },
    ],
  },
  {
    title: '神経解套注射（ハイドロリリース）',
    faqs: [
      { q: '神経解套注射後はどんな感じですか？', a: '使用するのは体液と同じ浸透圧の5%ブドウ糖液のため、術後の痠痛は増生療法より軽いことがほとんどです。神経の損傷が長期化している場合は強い痠痛を感じることもありますが、多くは1〜3日で落ち着きます。注射直後から改善を感じる方も多いです。' },
      { q: '増生療法の注射液と同じですか？', a: '異なります。神経解套注射では5%低濃度ブドウ糖を使用し、神経周囲の組織を物理的に剥離して神経圧迫を解放・安定させることが目的です。増生療法では10〜25%高濃度ブドウ糖を使用し、軽度の炎症を誘発して組織修復を促します。目的と作用機序が異なります。' },
      { q: '何回治療が必要ですか？', a: '通常2〜4週間ごとに1回、3〜6回程度の治療が必要です。神経の損傷が重篤な場合はPRPを用いた神経解套注射も選択肢となり、この場合は4〜6週間ごとの治療となります。' },
      { q: '神経解套後もリハビリは必要ですか？', a: 'はい。症状が改善した後も、神経圧迫の根本原因（関節不安定性・筋肉の緊張など）に対処するため、リハビリや姿勢改善を続けることが再発予防につながります。' },
    ],
  },
  {
    title: 'ボツリヌス毒素疼痛注射',
    faqs: [
      { q: 'ボツリヌス毒素疼痛注射後の注意事項は？', a: '注射後4時間は注射部位を押さないようにしてください。24時間は激しい運動と高温環境（入浴・サウナなど）をお避けください。注射部位周辺に軽い脱力感が1〜3日現れることがありますが、正常な反応で数日以内に回復します。効果は注射後1〜2週間で徐々に現れ、3〜6ヶ月持続します。' },
      { q: '疼痛治療のボツリヌス毒素と美容ボトックスは同じですか？', a: '薬剤は同じですが、注射部位と目的が異なります。疼痛治療では筋肉の痙攣や慢性疼痛の原因となる筋肉群に注射します。美容目的の部位とは異なり、用量や評価基準も違います。疼痛科専門医による評価が必要です。' },
    ],
  },
]

const allFaqs = treatments.flatMap((t) => t.faqs)
---

<Layout
  lang={lang}
  pathname="treatment-faq"
  title="治療に関するよくある質問｜ゴラン診療所・蘆洲疼痛治療"
  description="PRP・増生療法・針刀・BMAC・TAME・ヒアルロン酸・SportVis・神経解套・ボツリヌス毒素による疼痛治療の前後によくある質問と術後ケアのご案内。"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: allFaqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })} />

  <section class="fv-hero">
    <div class="container">
      <p class="fv-eyebrow">よくある治療の質問</p>
      <h1>治療に関するよくある質問</h1>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <p>以下は、ゴラン診療所で提供している各治療に関するよくある質問をまとめたものです。治療前の準備から術後のケアまで、参考にしていただければ幸いです。その他ご不明な点はLINEまたはメールでお気軽にお問い合わせください。</p>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>治療後の共通注意事項</h2>
      <ul>
        {generalCare.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  {treatments.map((tr) => (
    <section class="fv-section fv-faq">
      <div class="container">
        <h2>{tr.title}</h2>
        {tr.faqs.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>
  ))}

  <section class="fv-section">
    <div class="container">
      <h2>その他のご質問はこちら</h2>
      <p>LINEまたはメールでお問い合わせください。営業日24時間以内にご返答いたします。</p>
      <div class="fv-cta-row">
        <a href={lineUrl} class="fv-cta fv-cta-line" target="_blank" rel="noopener">LINEで相談</a>
        <a href={mailUrl} class="fv-cta fv-cta-mail">メールでお問い合わせ</a>
        <a href={`/${lang}/`} class="fv-cta fv-cta-ghost">トップページへ戻る</a>
      </div>
    </div>
  </section>
</Layout>
