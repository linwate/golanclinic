---
import Layout from '../../../layouts/Layout.astro'
import { indexMeta } from '../../../data/symptoms'

const lang = 'en'
const meta = indexMeta[lang]
---

<Layout title={meta.title} description={meta.description} lang={lang} pathname="symptoms">
  <section class="fv-hero">
    <div class="container">
      <p class="fv-eyebrow">Pain Treatment · Luzhou</p>
      <h1>{meta.h1}</h1>
      <p class="fv-tagline">{meta.intro}</p>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <p class="symptom-index-lead">Select the category that best matches your symptoms.</p>
      <div class="symptom-cat-grid">

        <a href="/en/symptoms/shoulder/" class="symptom-cat-card">
          <span class="symptom-cat-label">Shoulder Pain</span>
          <span class="symptom-cat-sub">Frozen shoulder · Rotator cuff · Impingement</span>
        </a>

        <a href="/en/symptoms/neck/" class="symptom-cat-card">
          <span class="symptom-cat-label">Neck Pain</span>
          <span class="symptom-cat-sub">Cervical nerve · Cervicogenic headache · Numbness</span>
        </a>

        <a href="/en/symptoms/back/" class="symptom-cat-card">
          <span class="symptom-cat-label">Lower Back Pain</span>
          <span class="symptom-cat-sub">Disc herniation · Sacroiliac joint · Sciatica</span>
        </a>

        <a href="/en/symptoms/hip/" class="symptom-cat-card">
          <span class="symptom-cat-label">Hip & Buttock</span>
          <span class="symptom-cat-sub">Hip degeneration · Piriformis · GTPS</span>
        </a>

        <a href="/en/symptoms/knee/" class="symptom-cat-card">
          <span class="symptom-cat-label">Knee Degeneration</span>
          <span class="symptom-cat-sub">Osteoarthritis · Meniscus · Patellar tendinitis</span>
        </a>

        <a href="/en/symptoms/foot/" class="symptom-cat-card">
          <span class="symptom-cat-label">Foot & Ankle</span>
          <span class="symptom-cat-sub">Plantar fasciitis · Ankle instability · Achilles</span>
        </a>

        <a href="/en/symptoms/elbow-wrist/" class="symptom-cat-card">
          <span class="symptom-cat-label">Elbow & Wrist</span>
          <span class="symptom-cat-sub">Tennis elbow · Carpal tunnel · TFCC</span>
        </a>

        <a href="/en/symptoms/neuropathy/" class="symptom-cat-card">
          <span class="symptom-cat-label">Neuropathy</span>
          <span class="symptom-cat-sub">DPN · Nerve hydrodissection · Numbness</span>
        </a>

        <a href="https://twmedpro.tw" target="_blank" rel="noopener noreferrer" class="symptom-cat-card">
          <span class="symptom-cat-label">Sports Injuries</span>
          <span class="symptom-cat-sub">Baseball · Soccer · Pickleball · ACL</span>
        </a>

        <a href="/en/treatment-faq/" class="symptom-cat-card">
          <span class="symptom-cat-label">Vascular Therapy</span>
          <span class="symptom-cat-sub">TAME · Abnormal neovascularization</span>
        </a>

      </div>
    </div>
  </section>
</Layout>
