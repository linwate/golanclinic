---
import Layout from '../../../layouts/Layout.astro'
import { en, indexMeta } from '../../../data/symptoms'

const lang = 'en'
const meta = indexMeta[lang]
const slugs = ['shoulder', 'back', 'knee', 'foot', 'elbow-wrist', 'neuropathy']
---

<Layout title={meta.title} description={meta.description} lang={lang} pathname="symptoms">
  <section class="fv-hero">
    <div class="container">
      <h1>{meta.h1}</h1>
      <p class="fv-tagline">{meta.intro}</p>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <div class="symptom-index-grid">
        {slugs.map((slug) => {
          const d = en[slug]
          return (
            <a href={`/en/symptoms/${slug}/`} class="symptom-index-card">
              <h2>{d.h1}</h2>
              <p>{d.heroSub}</p>
              <ul>
                {d.category.cards.slice(0, 3).map((c) => <li>{c.name}</li>)}
              </ul>
            </a>
          )
        })}
      </div>
    </div>
  </section>
</Layout>
