---
import Layout from '../../../layouts/Layout.astro'
import { treatments, treatmentSlugs } from '../../../data/treatments'

const lang = 'en'
const slug = 'nerve-hydrodissection'
const data = treatments[lang][slug]
---

<Layout
  title={data.metaTitle}
  description={data.metaDescription}
  lang={lang}
  pathname={`treatments/${slug}`}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": data.h1,
    "description": data.whatIs,
    "step": data.steps.map((step, index) => ({
      "@type": "HowToStep",
      "position": index + 1,
      "name": `Step ${index + 1}`,
      "text": step
    }))
  })} />

  <section class="fv-hero">
    <div class="container">
      <p class="fv-eyebrow">{data.eyebrow}</p>
      <h1>{data.h1}</h1>
      <p class="fv-tagline">{data.heroSub}</p>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>What Is This Treatment</h2>
      <p>{data.whatIs}</p>
      <h2>Why It Matters</h2>
      <p>{data.whyImportant}</p>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>Who Is It Suitable For</h2>
      <ul class="treatment-suitable-list">
        {data.suitable.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>Treatment Process</h2>
      <ol class="treatment-steps-list">
        {data.steps.map((step) => <li>{step}</li>)}
      </ol>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>Our Approach</h2>
      <p>{data.clinicAdvantage}</p>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>Side Effects & Precautions</h2>
      <ul class="treatment-suitable-list">
        {data.sideEffects.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>Who Should Not Receive This Treatment</h2>
      <ul class="treatment-suitable-list treatment-contraindication-list">
        {data.contraindications.map((item) => <li>{item}</li>)}
      </ul>
      <p class="treatment-faq-link">
        <a href="/en/treatment-faq/">View full treatment FAQ →</a>
      </p>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>Pricing</h2>
      <p>{data.pricingNote}</p>
      <p class="treatment-faq-link">
        <a href="/en/pricing/">View full pricing →</a>
      </p>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>FAQ</h2>
      {data.faqItems.map((item) => (
        <div class="treatment-faq-item">
          <h3>{item.q}</h3>
          <p>{item.a}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>Related Symptoms</h2>
      <ul class="treatment-related-list">
        {data.relatedSymptoms.map((s) => (
          <li><a href={s.href}>{s.name}</a></li>
        ))}
      </ul>
    </div>
  </section>

  <section class="fv-section fv-cta-section">
    <div class="container">
      <h2>Questions Before Your Visit?</h2>
      <p class="fv-reply-note">
        Send us a message on LINE first — we'll help you figure out if this treatment is right for you.
      </p>
      <div class="fv-cta-row">
        <a href="https://line.me/R/ti/p/@twmedpro"
           class="fv-cta fv-cta-line" target="_blank" rel="noopener noreferrer">
          LINE Consultation
        </a>
        <a href="/en/first-visit/" class="fv-cta fv-cta-ghost">
          First Visit Guide
        </a>
      </div>
    </div>
  </section>
</Layout>
