---
import Layout from '../../layouts/Layout.astro'
import { useTranslations } from '../../i18n'

const lang = 'en'
const t = useTranslations(lang)
type Scope = keyof typeof t.services.scopes

const trainingFlags = ['🇰🇷', '🇯🇵', '🇰🇷', '🌍', '🇰🇷']
---

<Layout lang={lang}>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-tag">{t.hero.tag}</p>
      <h1 class="hero-title">
        {t.hero.title}<br />
        <span class="hero-title-accent">{t.hero.title2}</span>
      </h1>
      <p class="hero-sub">{t.hero.sub}</p>
      <a href="#book" class="btn-primary">{t.hero.cta}</a>
    </div>
  </section>

  <!-- STATS -->
  <div class="stats-bar">
    <div class="container">
      <div class="stats-grid">
        {t.stats.map((stat) => (
          <div class="stat-item">
            <span class="stat-num">{stat.num}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- PROBLEM -->
  <section class="problem">
    <div class="container">
      <h2 class="section-title">{t.problem.title}</h2>
      <ul class="problem-list">
        {t.problem.items.map((item) => (
          <li class="problem-item">
            <span class="problem-dot" aria-hidden="true"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <p class="problem-close">{t.problem.close}</p>
    </div>
  </section>

  <!-- APPROACH -->
  <section class="approach" id="approach">
    <div class="container">
      <p class="eyebrow">{t.approach.tag}</p>
      <h2 class="approach-title">
        {t.approach.title}
        <span class="approach-title-accent">{t.approach.title2}</span>
      </h2>
      <p class="approach-desc">{t.approach.desc}</p>
      <div class="approach-grid">
        {t.approach.points.map((p, i) => (
          <div class="approach-card">
            <span class="approach-num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="approach-label">{p.label}</h3>
            <p class="approach-text">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services" id="services">
    <div class="container">
      <h2 class="section-title">{t.services.title}</h2>
      <p class="services-sub">{t.services.sub}</p>
      {t.services.groups.map((group) => (
        <div class="section-block">
          <h3 class="section-sub-title">{group.title}</h3>
          <p class="section-sub-desc">{group.desc}</p>
          {'subgroups' in group ? (
            group.subgroups.map((sub) => (
              <div class="service-group">
                <div class="service-group-header">
                  <span class="service-group-label">{sub.label}</span>
                  <span class="service-group-desc">{sub.desc}</span>
                </div>
                <div class="self-pay-grid">
                  {sub.items.map((s) => (
                    <article class="service-card">
                      <span class="service-badge service-badge-private">
                        {t.services.scopes.private}
                      </span>
                      <h4 class="service-name">{s.name}</h4>
                      <p class="service-desc">{s.desc}</p>
                    </article>
                  ))}
                </div>
              </div>
            ))
          ) : (
            <div class={group.key === 'nhi' ? 'nhi-grid' : 'feature-grid'}>
              {group.items.map((s) => (
                <article class="service-card">
                  <span class={`service-badge service-badge-${s.scope}`}>
                    {t.services.scopes[s.scope as Scope]}
                  </span>
                  <h4 class="service-name">{s.name}</h4>
                  <p class="service-desc">{s.desc}</p>
                </article>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- PROCESS -->
  <section class="process" id="process">
    <div class="container">
      <h2 class="section-title">{t.process.title}</h2>
      <p class="process-sub">{t.process.sub}</p>

      <div class="process-type-tabs">
        <div class="process-type">
          <span class="process-type-label nhi">{t.process.nhiLabel}</span>
          <span class="process-type-note">{t.process.nhiNote}</span>
        </div>
        <div class="process-type">
          <span class="process-type-label self">{t.process.selfLabel}</span>
          <span class="process-type-note">{t.process.selfNote}</span>
        </div>
      </div>

      <div class="process-steps">
        {t.process.steps.map((step) => (
          <div class="process-step">
            <span class="process-num">{step.num}</span>
            <div class="process-content">
              <h3 class="process-title">{step.title}</h3>
              {step.desc && <p class="process-desc">{step.desc}</p>}
              {step.nhi && (
                <div class="process-split">
                  <div class="split-item nhi-item">
                    <span class="split-label">{t.process.nhiLabel}</span>
                    <p>{step.nhi}</p>
                  </div>
                  <div class="split-item self-item">
                    <span class="split-label">{t.process.selfLabel}</span>
                    <p>{step.self}</p>
                  </div>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DOCTOR -->
  <section class="doctor" id="about">
    <div class="container doctor-inner">
      <picture>
        <source srcset="/images/doctor.webp" type="image/webp" />
        <img
          src="/images/doctor.jpg"
          alt={t.doctor.title}
          class="doctor-photo"
          width="280"
          height="360"
          loading="lazy"
          decoding="async"
        />
      </picture>
      <div class="doctor-text">
        <p class="eyebrow eyebrow-light">{t.doctor.sub}</p>
        <h2 class="doctor-title">{t.doctor.title}</h2>
        <p class="doctor-desc">{t.doctor.desc}</p>
      </div>
    </div>
  </section>

  <!-- CREDENTIALS -->
  <section class="credentials" id="credentials">
    <div class="container">
      <h2 class="section-title">{t.credentials.title}</h2>
      <p class="credentials-sub">{t.credentials.sub}</p>
      <div class="credentials-grid">
        <div class="credentials-col">
          <h3 class="credentials-col-title">{t.credentials.licenses.title}</h3>
          <div class="credential-list">
            {t.credentials.licenses.items.map((item) => (
              <div class="credential-badge">
                <p class="credential-name">{item.name}</p>
                <p class="credential-note">{item.note}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="credentials-col">
          <h3 class="credentials-col-title">{t.credentials.training.title}</h3>
          <div class="training-list">
            {t.credentials.training.items.map((item, i) => (
              <a
                href={item.link}
                class="training-item"
                target="_blank"
                rel="noopener"
              >
                <span class="training-country" aria-hidden="true">{trainingFlags[i]}</span>
                <div class="training-body">
                  <p class="training-name">{item.name}</p>
                  <p class="training-desc">{item.desc}</p>
                  <span class="training-read">Read full article →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG -->
  <section class="blog-section" id="blog">
    <div class="container blog-inner">
      <div class="blog-text">
        <h2 class="section-title">{t.blog.title}</h2>
        <p class="blog-desc">{t.blog.desc}</p>
        <p class="blog-note">{t.blog.note}</p>
        <a href={t.blog.link} class="btn-primary" target="_blank" rel="noopener">
          {t.blog.cta} →
        </a>
      </div>
      <div class="blog-stat">
        <span class="blog-number">200+</span>
        <span class="blog-label">Articles</span>
      </div>
    </div>
    {t.blog.featured && (
      <div class="container">
        <div class="blog-featured">
          {t.blog.featured.map((article) => (
            <a
              href={article.url}
              class="blog-card"
              target="_blank"
              rel="noopener"
            >
              <span class="blog-card-tag">{article.tag}</span>
              <p class="blog-card-title">{article.title}</p>
              <span class="blog-card-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>

  <!-- FAQ -->
  <section class="faq" id="faq">
    <div class="container">
      <h2 class="section-title">{t.faq.title}</h2>
      <div class="faq-list">
        {t.faq.items.map((item) => (
          <details class="faq-item">
            <summary class="faq-q">{item.q}</summary>
            <p class="faq-a">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- HOURS -->
  <section class="hours" id="hours">
    <div class="container">
      <h2 class="section-title">{t.hours.title}</h2>
      <p class="hours-note">{t.hours.note}</p>
      <div class="hours-grid">
        {t.hours.slots.map((slot) => (
          <div class="hours-row">
            <span class="hours-day">{slot.day}</span>
            <span class="hours-time">{slot.time}</span>
          </div>
        ))}
      </div>
      <p class="hours-emergency">{t.hours.emergency}</p>
    </div>
  </section>

  <!-- BOOK -->
  <section class="book" id="book">
    <div class="container book-inner">
      <h2 class="book-title">{t.book.title}</h2>
      <p class="book-sub">{t.book.sub}</p>
      <a
        href="https://line.me/R/ti/p/@golanclinic"
        class="btn-primary btn-large"
        target="_blank"
        rel="noopener"
      >
        {t.book.cta}
      </a>
      <figure class="book-qr">
        <img src="/images/line-qr.png" alt={t.book.qrLabel} width="180" height="180" loading="lazy" />
        <figcaption>{t.book.qrLabel}</figcaption>
      </figure>
      <p class="book-addr">{t.book.addr}</p>
      <a href={t.book.mapLink} class="map-link" target="_blank" rel="noopener">
        {t.book.mapLabel}
      </a>
      <p class="book-hours">{t.book.hours}</p>
    </div>
  </section>
</Layout>
