---
import Layout from '../../layouts/Layout.astro'
const lang = 'en'
---

<Layout
  title="Dr. Lin Wei-De | Colan Clinic · Luzhou Pain Medicine"
  description="Dr. Lin Wei-De is a neurology-trained physician with CIPS certification, specializing in ultrasound-guided injection and regenerative medicine at Colan Clinic in Luzhou, New Taipei."
  lang={lang}
  pathname="about"
>

  <section class="fv-hero">
    <div class="container">
      <p class="fv-eyebrow">About the Physician</p>
      <h1>Dr. Lin Wei-De</h1>
      <p class="fv-tagline">Neurology-trained · CIPS Certified · Ultrasound-Guided Pain Medicine</p>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>About Dr. Lin</h2>
      <p>Dr. Lin Wei-De holds specialty training in neurology, traditional Chinese medicine, and pain medicine. After completing his residency in the Department of Neurology at Chang Gung Memorial Hospital (Linkou), he integrated ultrasound guidance and regenerative medicine into a focused practice treating chronic pain, neuropathy, and degenerative joint conditions without surgery.</p>
      <p>The philosophy behind Colan Clinic — "not just pain relief, but repair" — reflects Dr. Lin's emphasis on identifying the root cause of pain. Ultrasound is not a supplementary tool in his practice; it is central to both diagnosis and treatment, ensuring every injection is visible and precisely placed.</p>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>Certifications & Licenses</h2>
      <ul class="about-credential-list">
        <li>
          <span class="credential-title">Certified Interventional Pain Sonologist (CIPS)</span>
          <span class="credential-org">World Institute of Pain (WIP) · Credential No. 418</span>
          <a href="https://www.worldinstituteofpain.org" target="_blank" rel="noopener noreferrer" class="credential-link">World Institute of Pain ↗</a>
        </li>
        <li>
          <span class="credential-title">Board-Certified Neurologist</span>
          <span class="credential-org">Taiwan Neurological Society · No. 001426 · Valid through December 2027</span>
          <a href="https://www.neuro.org.tw/" target="_blank" rel="noopener noreferrer" class="credential-link">Taiwan Neurological Society ↗</a>
        </li>
        <li>
          <span class="credential-title">Pain Medicine Specialist</span>
          <span class="credential-org">Taiwan Pain Society · No. 714 · Valid through March 2029</span>
          <a href="https://pain.org.tw/" target="_blank" rel="noopener noreferrer" class="credential-link">Taiwan Pain Society ↗</a>
        </li>
        <li>
          <span class="credential-title">Physician License — Western & Chinese Medicine</span>
          <span class="credential-org">Taiwan Ministry of Health and Welfare · Issued April 2015 · No. 053036</span>
          <a href="https://ma.mohw.gov.tw/Accessibility/DOCSearch/DOCBasicData?DOC_SEQ=9TE4LdVDm9%252BdmVCAjlafHQ%253D%253D" target="_blank" rel="noopener noreferrer" class="credential-link">MOHW Physician Registry ↗</a>
        </li>
      </ul>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>Professional Experience</h2>
      <ul class="about-career-list">
        <li>
          <span class="career-period">Late 2026 (Opening)</span>
          <span class="career-title">Colan Clinic · Pain Medicine · Regenerative Injection · Chronic Degeneration</span>
          <span class="career-org">Luzhou District, New Taipei City</span>
        </li>
        <li>
          <span class="career-period">Jun 2025 – Present</span>
          <span class="career-title">Shengsheng Youdong Clinic · Pain Medicine · Regenerative Injection</span>
          <span class="career-org">Banqiao District, New Taipei City</span>
        </li>
        <li>
          <span class="career-period">May 2023 – Present</span>
          <span class="career-title">Weide Orthopedic Clinic · Pain Medicine · Regenerative Injection</span>
          <span class="career-org">Sanchong District, New Taipei City</span>
        </li>
        <li>
          <span class="career-period">Mar 2021 – Aug 2024</span>
          <span class="career-title">Chong Ren Clinic · Neurologist & General Practitioner</span>
          <span class="career-org">New Taipei City</span>
        </li>
        <li>
          <span class="career-period">Aug 2016 – Feb 2021</span>
          <span class="career-title">Chang Gung Memorial Hospital (Linkou) · Neurology Resident</span>
          <span class="career-org">Taoyuan City</span>
        </li>
      </ul>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>Publications</h2>
      <ul class="about-publication-list">
        <li>
          <span class="pub-title">Modification of Mechanical Properties, Polymerization Temperature, and Handling Time of Polymethylmethacrylate Cement for Enhancing Applicability in Vertebroplasty</span>
          <span class="pub-journal">BioMed Research International · 2016</span>
          <a href="https://doi.org/10.1155/2016/7901562" target="_blank" rel="noopener noreferrer" class="credential-link">DOI: 10.1155/2016/7901562 ↗</a>
        </li>
      </ul>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>Academic Profiles</h2>
      <ul class="about-external-list">
        <li>
          <a href="https://orcid.org/0000-0003-2380-9104" target="_blank" rel="noopener noreferrer" class="credential-link">
            ORCID: 0000-0003-2380-9104 ↗
          </a>
        </li>
        <li>
          <a href="https://www.linkedin.com/in/weide-lin-5268b897/" target="_blank" rel="noopener noreferrer" class="credential-link">
            LinkedIn: Wei-De Lin ↗
          </a>
        </li>
        <li>
          <a href="https://twmedpro.tw/drlinwate/" target="_blank" rel="noopener noreferrer" class="credential-link">
            Pain Medicine Blog (twmedpro.tw) ↗
          </a>
        </li>
      </ul>
    </div>
  </section>

  <section class="fv-section fv-cta-section">
    <div class="container">
      <h2>Questions Before Your Visit?</h2>
      <p class="fv-reply-note">
        Send us a message on LINE to describe your symptoms. Dr. Lin will help you determine the right direction before you decide whether to book an appointment.
      </p>
      <div class="fv-cta-row">
        <a href="https://line.me/R/ti/p/@twmedpro"
           class="fv-cta fv-cta-line" target="_blank" rel="noopener noreferrer">
          LINE Consultation
        </a>
        <a href="/en/first-visit/" class="fv-cta fv-cta-ghost">
          First Visit Guide
        </a>
      </div>
    </div>
  </section>

</Layout>
