---
import Layout from '../../layouts/Layout.astro'

const lang = 'zh' as const

const lineUrl = 'https://line.me/R/ti/p/@twmedpro'

const generalCare = [
  '治療後 24 小時內避免泡澡',
  '注射部位出現輕微痠脹是正常反應，不必擔心',
  '避免使用消炎藥（NSAIDs 如布洛芬、Voltaren），疼痛時用普拿疼即可',
  '出現發燒、紅腫熱痛加劇、異常無力請立即回診或聯繫診所',
  '掛號及診察費僅接受現金付款。自費治療項目接受現金及信用卡（Visa、Mastercard）。',
]

const treatments = [
  {
    title: 'PRP 增生療法',
    faqs: [
      { q: 'PRP 注射後為什麼會更痛？', a: '注射後 1 到 2 週內出現局部痠脹感是正常現象，因為 PRP 是透過誘發輕度發炎來啟動修復機制。通常 48 小時最明顯，少數人持續至兩週。可冰敷或服用普拿疼緩解。' },
      { q: 'PRP 後可以吃消炎藥嗎？', a: '不建議。NSAIDs 和類固醇會抑制發炎反應，而發炎正是 PRP 啟動修復的必要機制。疼痛難耐時只能用普拿疼類止痛藥。' },
      { q: 'PRP 後多久可以運動？', a: '注射後 48 到 72 小時內避免劇烈運動，可正常步行。1 到 2 週痠脹感緩解後，可開始循序漸進的復健訓練。高衝擊性運動需和醫師確認後再恢復。' },
      { q: 'PRP 飲食上要注意什麼？', a: '多攝取蛋白質、維生素 B 和 C。治療前後一週避免飲酒，酒精會影響血小板品質。' },
    ],
  },
  {
    title: '增生療法（葡萄糖注射）',
    faqs: [
      { q: '增生療法注射後有什麼感覺？', a: '注射部位會有局部痠脹感，通常持續 1 到 3 天，少數人至 7 天。這是正常的發炎修復反應，可冰敷或服用普拿疼。同樣不建議使用消炎藥。' },
      { q: '增生療法和 PRP 術後照護一樣嗎？', a: '基本相同，都要避免消炎藥、避免劇烈運動、補充足夠營養。主要差異是增生療法的痠脹感通常比 PRP 輕微，恢復期也較短。' },
    ],
  },
  {
    title: '針刀整合治療',
    faqs: [
      { q: '針刀治療後要注意什麼？', a: '治療當天避免泡澡、游泳，保持針孔乾燥 24 小時。治療部位可能有痠脹感或輕微瘀青，屬正常現象，1 到 3 天內消退。避免劇烈運動 48 小時，可正常行走。出現紅腫熱痛加劇或發燒請立即回診。' },
      { q: '針刀後可以繼續復健嗎？', a: '可以，而且建議搭配。針刀鬆解沾黏後，配合適當伸展和復健運動效果更好。建議治療後 2 到 3 天痠脹感緩解後再開始，動作以不引發劇烈疼痛為原則。' },
    ],
  },
  {
    title: 'BMAC 骨髓細胞濃縮液',
    faqs: [
      { q: 'BMAC 抽骨髓很痛嗎？', a: '抽取前會先進行局部麻醉，將疼痛感降到最低。過程中可能有些許痠脹感，抽取位置是骨盆髂骨，不是脊椎，不會影響神經。骨髓和血液一樣可以自行再生，攝取足夠營養和休息後會自行補充。' },
      { q: 'BMAC 和脊髓液有關係嗎？', a: '完全無關。骨髓是骨骼內的造血組織，抽取位置在骨盆髂骨。脊髓液是包圍脊髓神經的液體，是完全不同的概念，BMAC 治療不會碰觸到脊椎或神經系統。' },
      { q: 'BMAC 治療後需要住院嗎？', a: '不需要。整個療程約 1 到 1.5 小時在門診完成，治療後休息一下即可返家。建議當天避免開車，由家人陪同較佳。' },
      { q: 'BMAC 後多久可以運動？', a: '治療後 48 到 72 小時內避免劇烈活動，避免負重過大。通常 1 到 2 週後可開始輕度復健，具體時程請在門診確認。' },
    ],
  },
  {
    title: 'Simple TAME 微細動脈栓塞',
    faqs: [
      { q: '鈷嵐診所的 TAME 是導管手術嗎？', a: '不是。本診所執行的是 Simple TAME，使用超音波即時導引，直接將藥物精準注射至異常新生血管部位，不需插入導管，不需住院，門診當天完成。' },
      { q: 'Simple TAME 注射後要注意什麼？', a: '注射後 24 小時內避免泡澡，保持注射部位乾燥。治療部位可能有輕微痠脹感，1 到 3 天內消退。治療後第 2 天起可進行不引起疼痛的輕度活動，劇烈運動和重度負重請循序漸進恢復。' },
      { q: 'Simple TAME 和導管 TAME 有什麼不同？', a: '導管 TAME 需從手腕或腹股溝深入血管；Simple TAME 使用超音波導引直接從體表注射，侵入性更低、恢復更快、門診即可完成。兩者目標相同，都是消除引起疼痛的異常新生血管，適合的患者和嚴重程度有所不同。' },
      { q: '需要住院嗎？', a: '不需要。Simple TAME 為門診治療，注射完休息一下即可返家。' },
      { q: '治療要打幾次？', a: '通常需要 2 到 3 次，每次間隔依個人恢復狀況而定。門診時醫師會根據超音波評估結果說明建議次數和間隔。' },
    ],
  },
  {
    title: '關節玻尿酸注射',
    faqs: [
      { q: '玻尿酸注射後要注意什麼？', a: '注射後 24 到 48 小時內避免劇烈運動和長時間負重。部分患者注射後 1 到 2 天會有輕微脹痛感，屬正常反應，可冰敷緩解。避免注射部位受熱 24 小時。' },
      { q: '玻尿酸注射多久見效？多久打一次？', a: '效果因人而異，通常注射後 1 到 4 週逐漸感覺改善。依劑型不同，效果可維持 6 個月至 1 年。需要再次注射的時機請與醫師討論。' },
    ],
  },
  {
    title: 'SportVis 舒健玻尿酸',
    faqs: [
      { q: 'SportVis 和一般玻尿酸有什麼不同？', a: '一般玻尿酸主要用於關節潤滑；SportVis 是專為肌腱和韌帶修復設計的特殊玻尿酸，能嵌入受傷的軟組織，同時具備修復、潤滑和控制發炎三種作用，是目前台灣 TFDA 核准用於肌腱韌帶修復的玻尿酸製劑。' },
      { q: 'SportVis 注射後要注意什麼？', a: '注射後依部位可能需要做幾次特定動作，幫助藥物均勻分布。注射後 24 到 48 小時避免劇烈運動，可正常日常活動。術後不適感通常比 PRP 輕微，多數患者可較快恢復正常活動。' },
      { q: 'SportVis 療程要打幾次？', a: '標準療程通常為 2 次，間隔 4 到 7 天。急性扭傷建議在受傷 48 小時內完成第一劑效果最佳。' },
    ],
  },
  {
    title: '神經解套注射',
    faqs: [
      { q: '神經解套注射後有什麼感覺？', a: '因使用 5% 低濃度葡萄糖水，與人體滲透壓相同，注射後痠脹感通常比增生療法輕微。部分神經受傷較久的患者可能有較強痠痛感，多在 1 到 3 天內緩解。效果通常注射後立竿見影。' },
      { q: '神經解套和增生療法的注射液一樣嗎？', a: '不一樣。神經解套使用 5% 低濃度葡萄糖，目的是物理上分離神經與周圍組織、穩定神經、減少神經發炎；增生療法使用 10 到 25% 高濃度葡萄糖，目的是刺激輕度發炎啟動組織修復。兩者目的和作用機制不同。' },
      { q: '神經解套需要打幾次才有效？', a: '一般每 2 到 4 週治療一次，可能需要 3 到 6 次才能穩定。神經受損較嚴重的案例可改用 PRP 神經解套注射，療效更強，間隔可延長至 4 到 6 週一次。' },
      { q: '神經解套後需要繼續復健嗎？', a: '建議搭配。神經解套改善症狀後，仍需找出造成神經壓迫的根本原因，並配合復健治療和姿勢調整，才能避免復發。' },
    ],
  },
  {
    title: '肉毒桿菌止痛注射',
    faqs: [
      { q: '肉毒桿菌止痛注射後要注意什麼？', a: '注射後 4 小時內避免按壓注射部位，24 小時內避免劇烈運動和高溫環境。部分患者注射後 1 到 3 天出現注射部位輕微無力感，屬正常反應，通常數天內恢復。效果通常在注射後 1 到 2 週逐漸出現，持續 3 到 6 個月。' },
      { q: '肉毒桿菌止痛和醫美肉毒一樣嗎？', a: '藥物相同，但注射位置和目的不同。疼痛治療的肉毒注射針對的是肌肉痙攣和慢性疼痛，注射在引起疼痛的肌肉群，不是臉部美容的位置。劑量和評估標準也不同，需要由疼痛科醫師評估。' },
    ],
  },
]

const allFaqs = treatments.flatMap((t) => t.faqs)
---

<Layout
  lang={lang}
  pathname="treatment-faq"
  title="治療常見問題｜鈷嵐診所・蘆洲疼痛治療"
  description="PRP、增生療法、針刀、BMAC、TAME、玻尿酸、SportVis、神經解套、肉毒止痛注射前後的常見問題與術後注意事項。"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: allFaqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })} />

  <section class="fv-hero">
    <div class="container">
      <p class="fv-eyebrow">常見治療問題</p>
      <h1>治療常見問題</h1>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <p>以下整理了鈷嵐診所各項治療的常見問題，包含治療前的評估說明、術後注意事項與恢復期建議。如有其他疑問，歡迎透過 LINE 諮詢。</p>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <h2>共同注意事項</h2>
      <p>不論接受哪種治療，以下原則通用：</p>
      <ul>
        {generalCare.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  {treatments.map((tr) => (
    <section class="fv-section fv-faq">
      <div class="container">
        <h2>{tr.title}</h2>
        {tr.faqs.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>
  ))}

  <section class="fv-section">
    <div class="container">
      <h2>還有其他問題？</h2>
      <p>歡迎透過 LINE 諮詢，工作日 24 小時內回覆。</p>
      <div class="fv-cta-row">
        <a href={lineUrl} class="fv-cta fv-cta-line" target="_blank" rel="noopener">加入 LINE 諮詢</a>
        <a href="mailto:info@colanclinic.com" class="fv-cta fv-cta-mail">Email 詢問</a>
        <a href={`/${lang}/`} class="fv-cta fv-cta-ghost">返回首頁</a>
      </div>
    </div>
  </section>
</Layout>
