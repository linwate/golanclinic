---
import Layout from '../../../layouts/Layout.astro'
import { indexMeta } from '../../../data/symptoms'

const lang = 'zh'
const meta = indexMeta[lang]
---

<Layout title={meta.title} description={meta.description} lang={lang} pathname="symptoms">
  <section class="fv-hero">
    <div class="container">
      <h1>{meta.h1}</h1>
      <p class="fv-tagline">{meta.intro}</p>
    </div>
  </section>

  <section class="fv-section">
    <div class="container">
      <p class="symptom-index-lead">選擇最接近你症狀的分類，找到可能的原因和治療方向。</p>
      <div class="symptom-cat-grid">

        <a href="/zh/symptoms/shoulder/" class="symptom-cat-card">
          <span class="symptom-cat-label">肩膀疼痛</span>
          <span class="symptom-cat-sub">五十肩・旋轉肌・肩峰下夾擠</span>
        </a>

        <a href="/zh/symptoms/neck/" class="symptom-cat-card">
          <span class="symptom-cat-label">頸部疼痛</span>
          <span class="symptom-cat-sub">頸椎壓迫・頸因性頭痛・手麻</span>
        </a>

        <a href="/zh/symptoms/back/" class="symptom-cat-card">
          <span class="symptom-cat-label">下背痛</span>
          <span class="symptom-cat-sub">腰椎間盤・薦髂關節・坐骨神經</span>
        </a>

        <a href="/zh/symptoms/hip/" class="symptom-cat-card">
          <span class="symptom-cat-label">髖臀疼痛</span>
          <span class="symptom-cat-sub">髖關節退化・梨狀肌・大轉子</span>
        </a>

        <a href="/zh/symptoms/knee/" class="symptom-cat-card">
          <span class="symptom-cat-label">膝蓋退化</span>
          <span class="symptom-cat-sub">退化性關節炎・半月板・跳躍膝</span>
        </a>

        <a href="/zh/symptoms/foot/" class="symptom-cat-card">
          <span class="symptom-cat-label">足踝疼痛</span>
          <span class="symptom-cat-sub">足底筋膜炎・腳踝扭傷・跟腱炎</span>
        </a>

        <a href="/zh/symptoms/elbow-wrist/" class="symptom-cat-card">
          <span class="symptom-cat-label">手肘手腕</span>
          <span class="symptom-cat-sub">網球肘・腕隧道・TFCC・板機指</span>
        </a>

        <a href="/zh/symptoms/neuropathy/" class="symptom-cat-card">
          <span class="symptom-cat-label">神經病變</span>
          <span class="symptom-cat-sub">DPN・神經解套・手麻腳麻</span>
        </a>

        <a href="https://twmedpro.tw" target="_blank" rel="noopener noreferrer" class="symptom-cat-card">
          <span class="symptom-cat-label">運動傷害</span>
          <span class="symptom-cat-sub">棒球・足球・皮克球・ACL・跟腱</span>
        </a>

        <a href="/zh/treatment-faq/" class="symptom-cat-card">
          <span class="symptom-cat-label">血管治療</span>
          <span class="symptom-cat-sub">TAME 微細動脈栓塞・異常新生血管</span>
        </a>

      </div>
    </div>
  </section>
</Layout>
