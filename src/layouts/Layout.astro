---
import '../styles/global.css'
import { useTranslations, type Lang } from '../i18n'
import announcementData from '../data/announcement.json'

export interface Props {
  lang: Lang
  title?: string
  description?: string
}

const { lang } = Astro.props
const t = useTranslations(lang)

const title = Astro.props.title || t.site.title
const description = Astro.props.description || t.site.description
const canonical = `https://golanclinic.com/${lang}/`
const ogImage = 'https://golanclinic.com/images/doctor.webp'

const announcement = announcementData as {
  zh: string
  en: string
  ja: string
  active: boolean
}
const announcementText = announcement.active ? announcement[lang] : ''

const lineUrl = 'https://line.me/R/ti/p/@golanclinic'

const htmlLang: Record<Lang, string> = {
  zh: 'zh-Hant',
  en: 'en',
  ja: 'ja',
}
const ogLocale: Record<Lang, string> = {
  zh: 'zh_TW',
  en: 'en_US',
  ja: 'ja_JP',
}
const langLabel: Record<Lang, string> = {
  zh: '中',
  en: 'EN',
  ja: '日',
}
const langOrder: Lang[] = ['zh', 'en', 'ja']
const otherLangs = langOrder.filter((l) => l !== lang) as Lang[]
const hreflangOf: Record<Lang, string> = {
  zh: 'zh-TW',
  en: 'en',
  ja: 'ja',
}
---

<!DOCTYPE html>
<html lang={htmlLang[lang]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#1a2f6e" />

    <!-- Basic SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={t.site.keywords} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="鈷嵐診所 Golan Clinic" />
    <meta property="og:locale" content={ogLocale[lang]} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- hreflang (absolute URLs for SEO clarity) -->
    <link rel="alternate" hreflang="zh-TW" href="https://golanclinic.com/zh/" />
    <link rel="alternate" hreflang="en" href="https://golanclinic.com/en/" />
    <link rel="alternate" hreflang="ja" href="https://golanclinic.com/ja/" />
    <link rel="alternate" hreflang="x-default" href="https://golanclinic.com/zh/" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- MedicalClinic + Physician structured data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'MedicalClinic',
      name: '鈷嵐診所',
      alternateName: ['Golan Clinic', 'ゴラン診療所'],
      description: '神經科暨疼痛專科診所，提供超音波導引注射、PRP、神經解套、BMAC再生醫學',
      url: 'https://golanclinic.com',
      image: ogImage,
      telephone: '',
      priceRange: '$$',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '永安北路二段58巷6號',
        addressLocality: '蘆洲區',
        addressRegion: '新北市',
        postalCode: '247',
        addressCountry: 'TW',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 25.0827,
        longitude: 121.4676,
      },
      hasMap: 'https://maps.app.goo.gl/WYC9Hb8qjyi6CbLj8',
      medicalSpecialty: ['Neurology', 'PainMedicine', 'RegenerativeMedicine'],
      openingHoursSpecification: [{
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      }],
      physician: {
        '@type': 'Physician',
        name: '林瑋德',
        alternateName: 'Dr. Lin Wei-de',
        medicalSpecialty: ['Neurology', 'PainMedicine'],
      },
      sameAs: [],
    })} />
    <!-- Twemoji: replace native emoji with SVG for consistent rendering on all OS.
         Default MaxCDN base is dead, so we pin `base` to jsDelivr. -->
    <script src="https://cdn.jsdelivr.net/npm/twemoji@14/dist/twemoji.min.js" crossorigin="anonymous" is:inline></script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        if (window.twemoji) {
          window.twemoji.parse(document.body, {
            folder: 'svg',
            ext: '.svg',
            base: 'https://cdn.jsdelivr.net/gh/twitter/twemoji@14.0.2/assets/',
          });
        }
      });
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    {announcementText && (
      <div class="announcement-bar" role="status">
        <div class="announcement-inner">
          <span class="announcement-icon" aria-hidden="true">📢</span>
          <span class="announcement-text">{announcementText}</span>
          <button
            type="button"
            class="announcement-close"
            aria-label="關閉公告"
            onclick="this.closest('.announcement-bar').style.display='none'"
          >✕</button>
        </div>
      </div>
    )}
    <nav class="nav" aria-label="Primary">
      <div class="nav-inner">
        <a href={`/${lang}/`} class="nav-logo">
          <span class="nav-logo-mark" aria-hidden="true"></span>
          <span class="nav-logo-text">{t.site.title}</span>
        </a>
        <div class="nav-links">
          <a href="#approach">{t.nav.approach}</a>
          <a href="#services">{t.nav.services}</a>
          <a href="#about">{t.nav.about}</a>
          <a href="#faq">{t.nav.faq}</a>
          <a href="#book" class="nav-cta">{t.nav.book}</a>
        </div>
        <a href="#book" class="nav-mobile-cta">{t.nav.book}</a>
        <div class="lang-switch" role="group" aria-label="Language">
          {otherLangs.map((l) => (
            <a href={`/${l}/`} hreflang={hreflangOf[l]} aria-label={`Switch to ${l}`}>{langLabel[l]}</a>
          ))}
        </div>
      </div>
    </nav>

    <main id="main"><slot /></main>

    <a
      href={lineUrl}
      class="line-float"
      target="_blank"
      rel="noopener"
      aria-label={t.nav.book}
    >
      <span class="line-float-dot" aria-hidden="true"></span>
      <span>{t.nav.book}</span>
    </a>

    <footer class="footer">
      <div class="footer-inner">
        <span>© {new Date().getFullYear()} {t.site.title}</span>
        <span class="footer-divider" aria-hidden="true">·</span>
        <span>{t.book.addr}</span>
        <span class="footer-divider" aria-hidden="true">·</span>
        <span>{t.book.hours}</span>
      </div>
    </footer>
  </body>
</html>
