---
import '../styles/global.css'
import { useTranslations, type Lang } from '../i18n'
import announcementData from '../data/announcement.json'
import { treatmentNavLabels, treatmentSlugs } from '../data/treatments'
import { symptomNavLabels } from '../data/symptoms'

export interface Props {
  lang: Lang
  title?: string
  description?: string
  /** Subpath under /<lang>/. e.g. 'first-visit' for /<lang>/first-visit/.
   *  Omit for the home page. Drives canonical, hreflang, nav-home prefix. */
  pathname?: string
}

const { lang, pathname = '' } = Astro.props
const t = useTranslations(lang)

const title = Astro.props.title || t.site.title
const description = Astro.props.description || t.site.description
// Normalize: strip leading/trailing slashes; non-empty → 'segment/'
const slug = pathname.replace(/^\/+|\/+$/g, '')
const pageSegment = slug ? `${slug}/` : ''
const canonical = `https://colanclinic.com/${lang}/${pageSegment}`
// On a subpage, nav anchors must navigate back to the home page first;
// on home, anchors are pure fragments.
const navHome = slug ? `/${lang}/` : ''
const ogImage = 'https://colanclinic.com/images/doctor.webp'

interface Settings {
  active?: boolean
}
interface Announcement {
  id: number
  zh: string
  en: string
  ja: string
  color?: string
  expires_at?: string | null
}
interface LangMap {
  zh?: string
  en?: string
  ja?: string
}
interface Modal {
  active?: boolean
  expires_at?: string | null
  title?: LangMap
  content?: LangMap
  cta_label?: LangMap
  cta_url?: string
}

const settings = (announcementData as { settings?: Settings }).settings ?? {}
const announcementsRaw = (announcementData as { announcements?: Announcement[] }).announcements ?? []
const modal: Modal = (announcementData as { modal?: Modal }).modal ?? {}

// Group toggle gates everything; then each ann is filtered by its own
// expires_at and non-empty text in the current language.
const nowIso = new Date().toISOString()
const groupActive = settings.active !== false
const activeAnns: Announcement[] = groupActive
  ? announcementsRaw.filter(
      (a) =>
        a[lang] &&
        a[lang].trim() !== '' &&
        (!a.expires_at || a.expires_at > nowIso),
    )
  : []

// Modal gate: active + not-expired + non-empty content in current lang.
const modalContent = modal.content?.[lang]?.trim() ?? ''
const showModal =
  modal.active === true &&
  (!modal.expires_at || modal.expires_at > nowIso) &&
  modalContent !== ''
const modalTitle = modal.title?.[lang] ?? ''
const modalCtaLabel = modal.cta_label?.[lang] ?? ''
const modalCtaUrl = modal.cta_url ?? ''

// Per-language ticker speed. Desktop and mobile are tuned independently
// because desktop's single-pass 1000px window has different pacing from
// mobile's seamless full-width loop. Wider CJK glyphs need a faster
// duration to keep characters-per-second readable; narrow Latin text
// needs a slower duration so it doesn't feel rushed.
const tickerSpeedMap: Record<Lang, { desktop: number; mobile: number }> = {
  zh: { desktop: 26, mobile: 22 },
  ja: { desktop: 28, mobile: 24 },
  en: { desktop: 32, mobile: 24 },
}
const tickerSpeedDesktop = tickerSpeedMap[lang].desktop
const tickerSpeedMobile = tickerSpeedMap[lang].mobile

const htmlLang: Record<Lang, string> = {
  zh: 'zh-Hant',
  en: 'en',
  ja: 'ja',
}
const ogLocale: Record<Lang, string> = {
  zh: 'zh_TW',
  en: 'en_US',
  ja: 'ja_JP',
}
const langLabel: Record<Lang, string> = {
  zh: '中',
  en: 'EN',
  ja: '日',
}
const langOrder: Lang[] = ['zh', 'en', 'ja']
const otherLangs = langOrder.filter((l) => l !== lang) as Lang[]
const hreflangOf: Record<Lang, string> = {
  zh: 'zh-TW',
  en: 'en',
  ja: 'ja',
}
---

<!DOCTYPE html>
<html lang={htmlLang[lang]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#1a2f6e" />

    <!-- Basic SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={t.site.keywords} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="鈷嵐診所 Colan Clinic" />
    <meta property="og:locale" content={ogLocale[lang]} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- hreflang (absolute URLs for SEO clarity) -->
    <link rel="alternate" hreflang="zh-TW" href={`https://colanclinic.com/zh/${pageSegment}`} />
    <link rel="alternate" hreflang="en" href={`https://colanclinic.com/en/${pageSegment}`} />
    <link rel="alternate" hreflang="ja" href={`https://colanclinic.com/ja/${pageSegment}`} />
    <link rel="alternate" hreflang="x-default" href={`https://colanclinic.com/zh/${pageSegment}`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600;700&family=Noto+Serif+TC:wght@400;500;600&display=swap"
      onload="this.onload=null;this.rel='stylesheet'">
    <noscript>
      <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600;700&family=Noto+Serif+TC:wght@400;500;600&display=swap">
    </noscript>

    <!-- MedicalClinic + Physician structured data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'MedicalClinic',
      name: '鈷嵐診所',
      alternateName: ['Colan Clinic', 'ゴラン診療所'],
      description: '神經科暨疼痛專科診所，提供超音波導引注射、PRP、神經解套、BMAC再生醫學',
      url: 'https://colanclinic.com',
      image: ogImage,
      telephone: '',
      priceRange: '$$',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '永安北路二段58巷6號',
        addressLocality: '蘆洲區',
        addressRegion: '新北市',
        postalCode: '247',
        addressCountry: 'TW',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 25.0827,
        longitude: 121.4676,
      },
      hasMap: 'https://maps.app.goo.gl/WYC9Hb8qjyi6CbLj8',
      medicalSpecialty: ['Neurology', 'PainMedicine', 'RegenerativeMedicine'],
      reviewedBy: {
        '@type': 'Physician',
        name: '林瑋德',
        alternateName: 'Lin Wei-De',
      },
      sameAs: [
        'https://line.me/R/ti/p/@twmedpro',
        'https://twmedpro.tw',
        'https://colanclinic.com/zh/about/',
      ],
    })} />

    <!-- Physician structured data (top-level, complements embedded one above) -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Physician',
      name: '林瑋德',
      alternateName: 'Lin Wei-De',
      jobTitle: '疼痛科醫師・神經科專科',
      worksFor: {
        '@type': 'MedicalClinic',
        name: '鈷嵐診所',
        url: 'https://colanclinic.com',
      },
      medicalSpecialty: ['Neurology', 'Pain Medicine', 'Regenerative Medicine'],
      url: `https://colanclinic.com/${lang}/`,
      sameAs: [
        'https://twmedpro.tw',
        'https://twmedpro.tw/drlinwate/',
        'https://orcid.org/0000-0003-2380-9104',
        'https://www.linkedin.com/in/weide-lin-5268b897/',
      ],
    })} />

    {slug && (slug.startsWith('symptoms') || slug.startsWith('treatments')) && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
          {
            "@type": "ListItem",
            "position": 1,
            "name": lang === 'zh' ? '首頁' : lang === 'en' ? 'Home' : 'ホーム',
            "item": `https://colanclinic.com/${lang}/`
          },
          slug.startsWith('treatments') ? {
            "@type": "ListItem",
            "position": 2,
            "name": lang === 'zh' ? '治療項目' : lang === 'en' ? 'Treatments' : '治療項目',
            "item": `https://colanclinic.com/${lang}/`
          } : {
            "@type": "ListItem",
            "position": 2,
            "name": lang === 'zh' ? '症狀查詢' : lang === 'en' ? 'Symptoms' : '症状から探す',
            "item": `https://colanclinic.com/${lang}/symptoms/`
          },
          ...(slug !== 'symptoms' ? [{
            "@type": "ListItem",
            "position": 3,
            "name": title.split(/[｜|]/)[0].trim(),
            "item": `https://colanclinic.com/${lang}/${slug}/`
          }] : [])
        ],
      })} />
    )}

    <!-- FAQPage structured data — only on the home page, where the
         visible FAQ list comes from t.faq.items. Subpages emit their
         own FAQPage schema inline so each URL has exactly one. -->
    {!slug && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: t.faq.items.map((item) => ({
          '@type': 'Question',
          name: item.q,
          acceptedAnswer: {
            '@type': 'Answer',
            text: item.a,
          },
        })),
      })} />
    )}

    <!-- Twemoji: replace native emoji with SVG for consistent rendering on all OS.
         Default MaxCDN base is dead, so we pin `base` to jsDelivr. -->
    <script defer src="https://cdn.jsdelivr.net/npm/twemoji@14/dist/twemoji.min.js" crossorigin="anonymous" is:inline></script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        if (window.twemoji) {
          window.twemoji.parse(document.body, {
            folder: 'svg',
            ext: '.svg',
            base: 'https://cdn.jsdelivr.net/gh/twitter/twemoji@14.0.2/assets/',
          });
        }
      });
    </script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XE7D8EDT6B" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XE7D8EDT6B');
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    {activeAnns.length > 0 && (
      <div
        class="announcement-ticker"
        role="status"
        style={`--ticker-speed: ${tickerSpeedDesktop}s; --ticker-speed-mobile: ${tickerSpeedMobile}s`}
      >
        <div class="ticker-inner">
          <div class="ticker-track">
            {[0, 1, 2, 3].map((rep) => (
              activeAnns.map((ann) => (
                <>
                  <span
                    class="ticker-text"
                    style={`color: ${ann.color || '#f2f0eb'}`}
                    {...(rep > 0 ? { 'aria-hidden': 'true' } : {})}
                  >{ann[lang]}</span>
                  <span class="ticker-sep" aria-hidden="true">・</span>
                </>
              ))
            ))}
          </div>
        </div>
      </div>
    )}

    {showModal && (
      <div class="modal-overlay" id="announcementModal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
        <div class="modal-box">
          <div class="modal-header">
            <span class="modal-icon" aria-hidden="true">📢</span>
            <h3 class="modal-title" id="modalTitle">{modalTitle}</h3>
            <button type="button" class="modal-close" id="modalClose" aria-label="關閉公告視窗">✕</button>
          </div>
          <div class="modal-body">
            <p class="modal-content">{modalContent}</p>
          </div>
          {modalCtaUrl && modalCtaLabel && (
            <div class="modal-footer">
              <a href={modalCtaUrl} class="modal-cta" target="_blank" rel="noopener">{modalCtaLabel}</a>
            </div>
          )}
        </div>
      </div>
      <script is:inline>
        (function () {
          var modal = document.getElementById('announcementModal');
          if (!modal) return;
          var closeBtn = document.getElementById('modalClose');

          // Per-content gating: sessionStorage key is derived from the
          // modal body text, so updating the announcement text invalidates
          // prior dismissals and visitors see the new version once.
          var contentEl = modal.querySelector('.modal-content');
          var modalContent = (contentEl && contentEl.textContent ? contentEl.textContent.trim() : '');
          var contentKey = 'modalSeen_' + btoa(encodeURIComponent(modalContent)).slice(0, 16);

          try {
            if (sessionStorage.getItem(contentKey)) {
              modal.classList.add('hidden');
            }
          } catch (e) { /* storage blocked — fall through to show */ }

          // Admin preview: `?modal=force` bypasses the gate and clears the
          // key so future testing in the same tab also shows the modal.
          try {
            var forceShow = new URLSearchParams(window.location.search).has('modal');
            if (forceShow) {
              modal.classList.remove('hidden');
              sessionStorage.removeItem(contentKey);
            }
          } catch (e) {}

          function closeModal() {
            modal.classList.add('hidden');
            try { sessionStorage.setItem(contentKey, '1'); } catch (e) {}
          }

          if (closeBtn) closeBtn.addEventListener('click', closeModal);
          modal.addEventListener('click', function (e) {
            if (e.target === modal) closeModal();
          });
          document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
          });
        })();
      </script>
    )}

    <nav class="nav" aria-label="Primary">
      <div class="nav-inner">
        <a href={`/${lang}/`} class="nav-logo">
          <span class="nav-logo-mark" aria-hidden="true"></span>
          <span class="nav-logo-text">{t.nav_logo}</span>
        </a>
        <button
          type="button"
          id="nav-burger"
          class="nav-burger"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="primary-nav-links"
        >
          <span class="nav-burger-bar"></span>
          <span class="nav-burger-bar"></span>
          <span class="nav-burger-bar"></span>
        </button>
        <div class="nav-links" id="primary-nav-links">
          <div class="nav-dropdown">
            <button type="button" class="nav-dropdown-btn" aria-expanded="false" tabindex="0">
              {t.nav.find_symptom}
              <span class="nav-dropdown-arrow">▾</span>
            </button>
            <div class="nav-dropdown-menu">
              <a href={`/${lang}/symptoms/`} class="nav-dropdown-item nav-dropdown-all">
                {lang === 'zh' ? '所有症狀查詢 →' : lang === 'en' ? 'All Symptoms →' : '症状一覧 →'}
              </a>
              <hr class="nav-dropdown-divider" />
              {['shoulder','neck','back','hip','knee','foot','elbow-wrist','neuropathy'].map((slug) => (
                <a href={`/${lang}/symptoms/${slug}/`} class="nav-dropdown-item">
                  {symptomNavLabels[lang][slug]}
                </a>
              ))}
            </div>
          </div>
          <div class="nav-dropdown">
            <button type="button" class="nav-dropdown-btn" aria-expanded="false" tabindex="0">
              {lang === 'zh' ? '治療項目' : lang === 'en' ? 'Treatments' : '治療項目'}
              <span class="nav-dropdown-arrow">▾</span>
            </button>
            <div class="nav-dropdown-menu">
              {treatmentSlugs.map((slug) => (
                <a href={`/${lang}/treatments/${slug}/`} class="nav-dropdown-item">
                  {treatmentNavLabels[lang][slug]}
                </a>
              ))}
            </div>
          </div>
          <a href={`${navHome}#services`}>{t.nav.services}</a>
          <a href={`/${lang}/pricing/`}>{t.nav.fees}</a>
          <a href={`/${lang}/about/`}>
            {lang === 'zh' ? '醫師介紹' : lang === 'en' ? 'About Dr. Lin' : '医師紹介'}
          </a>
          <a href={`/${lang}/first-visit/`}>{t.nav.first_visit}</a>
          <a href={`${navHome}#faq`}>{t.nav.faq}</a>
          <a href={`${navHome}#book`} class="nav-cta">{t.nav.book}</a>
        </div>
        <a href={`${navHome}#book`} class="nav-mobile-cta">{t.nav.book}</a>
        <div class="lang-switch" role="group" aria-label="Language">
          {otherLangs.map((l) => (
            <a href={`/${l}/${pageSegment}`} hreflang={hreflangOf[l]} aria-label={`Switch to ${l}`}>{langLabel[l]}</a>
          ))}
        </div>
      </div>
    </nav>
    <script is:inline>
      (function () {
        var btn = document.getElementById('nav-burger');
        var menu = document.getElementById('primary-nav-links');
        if (!btn || !menu) return;
        function close() {
          menu.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
          document.body.classList.remove('nav-open');
        }
        function open() {
          menu.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
          document.body.classList.add('nav-open');
        }
        btn.addEventListener('click', function () {
          if (menu.classList.contains('open')) close(); else open();
        });
        // Close after tapping any link inside the menu
        menu.addEventListener('click', function (e) {
          var t = e.target;
          while (t && t !== menu) {
            if (t.tagName === 'A') { close(); break; }
            t = t.parentNode;
          }
        });
        // Close on Esc
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && menu.classList.contains('open')) close();
        });

        // 下拉選單
        const dropdownBtns = document.querySelectorAll('.nav-dropdown-btn')

        function closeAll() {
          dropdownBtns.forEach((b) => b.setAttribute('aria-expanded', 'false'))
        }

        dropdownBtns.forEach((btn) => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation()
            const isOpen = btn.getAttribute('aria-expanded') === 'true'
            closeAll()
            if (!isOpen) {
              btn.setAttribute('aria-expanded', 'true')
            }
          })
        })

        // 點擊其他地方關閉
        document.addEventListener('click', closeAll)

        // ESC 關閉
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeAll()
        })
      })();
    </script>

    <main id="main">
      {pathname && pathname !== '' && (
        <nav class="breadcrumb-nav" aria-label="breadcrumb">
          <div class="container">
            <ol class="breadcrumb-list">
              <li class="breadcrumb-item">
                <a href={`/${lang}/`}>
                  {lang === 'zh' ? '首頁' : lang === 'en' ? 'Home' : 'ホーム'}
                </a>
              </li>
              {pathname.startsWith('symptoms/') && (
                <li class="breadcrumb-item">
                  <a href={`/${lang}/symptoms/`}>
                    {lang === 'zh' ? '症狀查詢' : lang === 'en' ? 'Symptoms' : '症状から探す'}
                  </a>
                </li>
              )}
              {pathname.startsWith('treatments/') && (
                <li class="breadcrumb-item">
                  <a href={`/${lang}/`}>
                    {lang === 'zh' ? '治療項目' : lang === 'en' ? 'Treatments' : '治療項目'}
                  </a>
                </li>
              )}
              {pathname === 'symptoms' && (
                <li class="breadcrumb-item breadcrumb-current" aria-current="page">
                  {lang === 'zh' ? '症狀查詢' : lang === 'en' ? 'Symptoms' : '症状から探す'}
                </li>
              )}
              {pathname !== 'symptoms' && pathname !== '' && (
                <li class="breadcrumb-item breadcrumb-current" aria-current="page">
                  {title.split(/[｜|]/)[0].trim()}
                </li>
              )}
            </ol>
          </div>
        </nav>
      )}
      <slot />

      <section class="fv-section map-section">
        <div class="container">
          <div class="map-wrapper">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3613.5260322753147!2d121.48262570000001!3d25.084048799999994!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3442a9458232f7e3%3A0x1d0f587ec5a23039!2z5p6X55GL5b636Yar5bir772c55a855eb6Ki66IGK5omA77yI6aCQ57SE5Yi277yJKOexjOWCmeiZlSk!5e0!3m2!1szh-TW!2stw!4v1778430699585!5m2!1szh-TW!2stw"
              width="100%"
              height="360"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={lang === 'zh' ? '鈷嵐診所位置地圖' : lang === 'en' ? 'Colan Clinic location map' : 'ゴラン診療所 位置図'}
              aria-label={lang === 'zh' ? 'Google Maps — 鈷嵐診所，新北市蘆洲區永安北路二段58巷6號' : lang === 'en' ? 'Google Maps — Colan Clinic, No. 6, Lane 58, Sec. 2, Yong\'an N. Rd., Luzhou Dist., New Taipei City' : 'Google Maps — ゴラン診療所、新北市蘆洲区永安北路二段58巷6号'}>
            </iframe>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-col footer-col-brand">
            <h2 class="footer-brand">{t.footer.brand}</h2>
            <p class="footer-tagline">{t.footer.tagline}</p>
          </div>
          <div class="footer-col">
            <h3 class="footer-col-title">{t.footer.addr_label}</h3>
            <p>{t.book.addr}</p>
          </div>
          <div class="footer-col">
            <h3 class="footer-col-title">{t.footer.hours_label}</h3>
            <p>{t.footer.hours_main}　{t.footer.hours_sub}</p>
            <p class="footer-note">{t.footer.reservation_note}</p>
          </div>
        </div>
        <div class="footer-rule" aria-hidden="true"></div>
        <div class="footer-bottom">
          <span class="footer-copyright">© {new Date().getFullYear()} {t.footer.copyright_brand}</span>
          <a class="footer-mail" href="mailto:info@colanclinic.com">info@colanclinic.com</a>
        </div>
      </div>
