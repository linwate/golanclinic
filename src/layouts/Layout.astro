---
import '../styles/global.css'
import { useTranslations, type Lang } from '../i18n'
import announcementData from '../data/announcement.json'

export interface Props {
  lang: Lang
  title?: string
  description?: string
  /** Subpath under /<lang>/. e.g. 'first-visit' for /<lang>/first-visit/.
   *  Omit for the home page. Drives canonical, hreflang, nav-home prefix. */
  pathname?: string
}

const { lang, pathname = '' } = Astro.props
const t = useTranslations(lang)

const title = Astro.props.title || t.site.title
const description = Astro.props.description || t.site.description
// Normalize: strip leading/trailing slashes; non-empty → 'segment/'
const slug = pathname.replace(/^\/+|\/+$/g, '')
const pageSegment = slug ? `${slug}/` : ''
const canonical = `https://golanclinic.com/${lang}/${pageSegment}`
// On a subpage, nav anchors must navigate back to the home page first;
// on home, anchors are pure fragments.
const navHome = slug ? `/${lang}/` : ''
const ogImage = 'https://golanclinic.com/images/doctor.webp'

interface Settings {
  active?: boolean
}
interface Announcement {
  id: number
  zh: string
  en: string
  ja: string
  color?: string
  expires_at?: string | null
}
interface LangMap {
  zh?: string
  en?: string
  ja?: string
}
interface Modal {
  active?: boolean
  expires_at?: string | null
  title?: LangMap
  content?: LangMap
  cta_label?: LangMap
  cta_url?: string
}

const settings = (announcementData as { settings?: Settings }).settings ?? {}
const announcementsRaw = (announcementData as { announcements?: Announcement[] }).announcements ?? []
const modal: Modal = (announcementData as { modal?: Modal }).modal ?? {}

// Group toggle gates everything; then each ann is filtered by its own
// expires_at and non-empty text in the current language.
const nowIso = new Date().toISOString()
const groupActive = settings.active !== false
const activeAnns: Announcement[] = groupActive
  ? announcementsRaw.filter(
      (a) =>
        a[lang] &&
        a[lang].trim() !== '' &&
        (!a.expires_at || a.expires_at > nowIso),
    )
  : []

// Modal gate: active + not-expired + non-empty content in current lang.
const modalContent = modal.content?.[lang]?.trim() ?? ''
const showModal =
  modal.active === true &&
  (!modal.expires_at || modal.expires_at > nowIso) &&
  modalContent !== ''
const modalTitle = modal.title?.[lang] ?? ''
const modalCtaLabel = modal.cta_label?.[lang] ?? ''
const modalCtaUrl = modal.cta_url ?? ''

// Per-language ticker speed. Desktop and mobile are tuned independently
// because desktop's single-pass 1000px window has different pacing from
// mobile's seamless full-width loop. Wider CJK glyphs need a faster
// duration to keep characters-per-second readable; narrow Latin text
// needs a slower duration so it doesn't feel rushed.
const tickerSpeedMap: Record<Lang, { desktop: number; mobile: number }> = {
  zh: { desktop: 26, mobile: 22 },
  ja: { desktop: 28, mobile: 24 },
  en: { desktop: 32, mobile: 24 },
}
const tickerSpeedDesktop = tickerSpeedMap[lang].desktop
const tickerSpeedMobile = tickerSpeedMap[lang].mobile

const htmlLang: Record<Lang, string> = {
  zh: 'zh-Hant',
  en: 'en',
  ja: 'ja',
}
const ogLocale: Record<Lang, string> = {
  zh: 'zh_TW',
  en: 'en_US',
  ja: 'ja_JP',
}
const langLabel: Record<Lang, string> = {
  zh: '中',
  en: 'EN',
  ja: '日',
}
const langOrder: Lang[] = ['zh', 'en', 'ja']
const otherLangs = langOrder.filter((l) => l !== lang) as Lang[]
const hreflangOf: Record<Lang, string> = {
  zh: 'zh-TW',
  en: 'en',
  ja: 'ja',
}
---

<!DOCTYPE html>
<html lang={htmlLang[lang]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#1a2f6e" />

    <!-- Basic SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={t.site.keywords} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="鈷嵐診所 Golan Clinic" />
    <meta property="og:locale" content={ogLocale[lang]} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- hreflang (absolute URLs for SEO clarity) -->
    <link rel="alternate" hreflang="zh-TW" href={`https://golanclinic.com/zh/${pageSegment}`} />
    <link rel="alternate" hreflang="en" href={`https://golanclinic.com/en/${pageSegment}`} />
    <link rel="alternate" hreflang="ja" href={`https://golanclinic.com/ja/${pageSegment}`} />
    <link rel="alternate" hreflang="x-default" href={`https://golanclinic.com/zh/${pageSegment}`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;700&family=Noto+Serif+TC:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- MedicalClinic + Physician structured data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'MedicalClinic',
      name: '鈷嵐診所',
      alternateName: ['Golan Clinic', 'ゴラン診療所'],
      description: '神經科暨疼痛專科診所，提供超音波導引注射、PRP、神經解套、BMAC再生醫學',
      url: 'https://golanclinic.com',
      image: ogImage,
      telephone: '',
      priceRange: '$$',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '永安北路二段58巷6號',
        addressLocality: '蘆洲區',
        addressRegion: '新北市',
        postalCode: '247',
        addressCountry: 'TW',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 25.0827,
        longitude: 121.4676,
      },
      hasMap: 'https://maps.app.goo.gl/WYC9Hb8qjyi6CbLj8',
      medicalSpecialty: ['Neurology', 'PainMedicine', 'RegenerativeMedicine'],
      openingHoursSpecification: [{
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      }],
      physician: {
        '@type': 'Physician',
        name: '林瑋德',
        alternateName: 'Dr. Lin Wei-de',
        medicalSpecialty: ['Neurology', 'PainMedicine'],
      },
      sameAs: [],
    })} />

    <!-- FAQPage structured data — only on the home page, where the
         visible FAQ list comes from t.faq.items. Subpages emit their
         own FAQPage schema inline so each URL has exactly one. -->
    {!slug && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: t.faq.items.map((item) => ({
          '@type': 'Question',
          name: item.q,
          acceptedAnswer: {
            '@type': 'Answer',
            text: item.a,
          },
        })),
      })} />
    )}

    <!-- Twemoji: replace native emoji with SVG for consistent rendering on all OS.
         Default MaxCDN base is dead, so we pin `base` to jsDelivr. -->
    <script src="https://cdn.jsdelivr.net/npm/twemoji@14/dist/twemoji.min.js" crossorigin="anonymous" is:inline></script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        if (window.twemoji) {
          window.twemoji.parse(document.body, {
            folder: 'svg',
            ext: '.svg',
            base: 'https://cdn.jsdelivr.net/gh/twitter/twemoji@14.0.2/assets/',
          });
        }
      });
    </script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XE7D8EDT6B" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XE7D8EDT6B');
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    {activeAnns.length > 0 && (
      <div
        class="announcement-ticker"
        role="status"
        style={`--ticker-speed: ${tickerSpeedDesktop}s; --ticker-speed-mobile: ${tickerSpeedMobile}s`}
      >
        <div class="ticker-inner">
          <div class="ticker-track">
            {[0, 1, 2, 3].map((rep) => (
              activeAnns.map((ann) => (
                <>
                  <span
                    class="ticker-text"
                    style={`color: ${ann.color || '#f2f0eb'}`}
                    {...(rep > 0 ? { 'aria-hidden': 'true' } : {})}
                  >{ann[lang]}</span>
                  <span class="ticker-sep" aria-hidden="true">・</span>
                </>
              ))
            ))}
          </div>
        </div>
      </div>
    )}

    {showModal && (
      <div class="modal-overlay" id="announcementModal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
        <div class="modal-box">
          <div class="modal-header">
            <span class="modal-icon" aria-hidden="true">📢</span>
            <h3 class="modal-title" id="modalTitle">{modalTitle}</h3>
            <button type="button" class="modal-close" id="modalClose" aria-label="關閉公告視窗">✕</button>
          </div>
          <div class="modal-body">
            <p class="modal-content">{modalContent}</p>
          </div>
          {modalCtaUrl && modalCtaLabel && (
            <div class="modal-footer">
              <a href={modalCtaUrl} class="modal-cta" target="_blank" rel="noopener">{modalCtaLabel}</a>
            </div>
          )}
        </div>
      </div>
      <script is:inline>
        (function () {
          var modal = document.getElementById('announcementModal');
          if (!modal) return;
          var closeBtn = document.getElementById('modalClose');

          // Per-content gating: sessionStorage key is derived from the
          // modal body text, so updating the announcement text invalidates
          // prior dismissals and visitors see the new version once.
          var contentEl = modal.querySelector('.modal-content');
          var modalContent = (contentEl && contentEl.textContent ? contentEl.textContent.trim() : '');
          var contentKey = 'modalSeen_' + btoa(encodeURIComponent(modalContent)).slice(0, 16);

          try {
            if (sessionStorage.getItem(contentKey)) {
              modal.classList.add('hidden');
            }
          } catch (e) { /* storage blocked — fall through to show */ }

          // Admin preview: `?modal=force` bypasses the gate and clears the
          // key so future testing in the same tab also shows the modal.
          try {
            var forceShow = new URLSearchParams(window.location.search).has('modal');
            if (forceShow) {
              modal.classList.remove('hidden');
              sessionStorage.removeItem(contentKey);
            }
          } catch (e) {}

          function closeModal() {
            modal.classList.add('hidden');
            try { sessionStorage.setItem(contentKey, '1'); } catch (e) {}
          }

          if (closeBtn) closeBtn.addEventListener('click', closeModal);
          modal.addEventListener('click', function (e) {
            if (e.target === modal) closeModal();
          });
          document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
          });
        })();
      </script>
    )}

    <nav class="nav" aria-label="Primary">
      <div class="nav-inner">
        <a href={`/${lang}/`} class="nav-logo">
          <span class="nav-logo-mark" aria-hidden="true"></span>
          <span class="nav-logo-text">{t.nav_logo}</span>
        </a>
        <button
          type="button"
          id="nav-burger"
          class="nav-burger"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="primary-nav-links"
        >
          <span class="nav-burger-bar"></span>
          <span class="nav-burger-bar"></span>
          <span class="nav-burger-bar"></span>
        </button>
        <div class="nav-links" id="primary-nav-links">
          <a href="https://twmedpro.tw" target="_blank" rel="noopener" class="nav-external">
            {t.nav.find_symptom}<span class="nav-external-icon" aria-hidden="true">↗</span>
          </a>
          <a href={`${navHome}#services`}>{t.nav.services}</a>
          <a href={`/${lang}/pricing/`}>{t.nav.fees}</a>
          <a href={`/${lang}/first-visit/`}>{t.nav.first_visit}</a>
          <a href={`${navHome}#about`}>{t.nav.about}</a>
          <a href={`${navHome}#faq`}>{t.nav.faq}</a>
          <a href={`${navHome}#book`} class="nav-cta">{t.nav.book}</a>
        </div>
        <a href={`${navHome}#book`} class="nav-mobile-cta">{t.nav.book}</a>
        <div class="lang-switch" role="group" aria-label="Language">
          {otherLangs.map((l) => (
            <a href={`/${l}/${pageSegment}`} hreflang={hreflangOf[l]} aria-label={`Switch to ${l}`}>{langLabel[l]}</a>
          ))}
        </div>
      </div>
    </nav>
    <script is:inline>
      (function () {
        var btn = document.getElementById('nav-burger');
        var menu = document.getElementById('primary-nav-links');
        if (!btn || !menu) return;
        function close() {
          menu.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
          document.body.classList.remove('nav-open');
        }
        function open() {
          menu.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
          document.body.classList.add('nav-open');
        }
        btn.addEventListener('click', function () {
          if (menu.classList.contains('open')) close(); else open();
        });
        // Close after tapping any link inside the menu
        menu.addEventListener('click', function (e) {
          var t = e.target;
          while (t && t !== menu) {
            if (t.tagName === 'A') { close(); break; }
            t = t.parentNode;
          }
        });
        // Close on Esc
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && menu.classList.contains('open')) close();
        });
      })();
    </script>

    <main id="main"><slot /></main>

    <a href={`${navHome}#book`} class="floating-cta" aria-label={t.nav.book}>
      <span class="floating-dot" aria-hidden="true"></span>
      <span>{t.nav.book}</span>
    </a>

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-col footer-col-brand">
            <h3 class="footer-brand">{t.footer.brand}</h3>
            <p class="footer-tagline">{t.footer.tagline}</p>
          </div>
          <div class="footer-col">
            <h4 class="footer-col-title">{t.footer.addr_label}</h4>
            <p>{t.book.addr}</p>
          </div>
          <div class="footer-col">
            <h4 class="footer-col-title">{t.footer.hours_label}</h4>
            <p>{t.footer.hours_main}　{t.footer.hours_sub}</p>
            <p class="footer-note">{t.footer.reservation_note}</p>
          </div>
        </div>
        <div class="footer-rule" aria-hidden="true"></div>
        <div class="footer-bottom">
          <span class="footer-copyright">© {new Date().getFullYear()} {t.footer.copyright_brand}</span>
          <a class="footer-mail" href="mailto:info@golanclinic.com">info@golanclinic.com</a>
        </div>
      </div>
    </footer>
  </body>
</html>
